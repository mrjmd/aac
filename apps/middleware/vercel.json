{
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@aac/middleware",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "crons": [
    {
      "path": "/api/cron/invoice-create",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/job-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/job-followups",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/deal-reconcile",
      "schedule": "0 14 * * *"
    }
  ]
}
